---
import Layout from '../layouts/Layout.astro';
import { accesoriosCategories } from '../data/content';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const contactoUrl = `${base}/contacto?asunto=Cotizaci%C3%B3n`;

const altIds = new Set(
  accesoriosCategories
    .filter((_, i) => i % 2 !== 0)
    .map(c => c.id)
);
---

<Layout
  title="Accesorios"
  description="Accesorios, lectores de identificación, monederos y refacciones originales para sistemas ULTREC."
>
  <div class="page-wrapper">
    <section class="page-header">
      <div class="container">
        <h1 class="page-title">Accesorios</h1>
        <p class="page-desc">
          Lectores de identificación, sistemas de cobro, refacciones originales y componentes complementarios
          para integrar y mantener tus equipos ULTREC en óptimas condiciones.
        </p>
      </div>
    </section>

    {accesoriosCategories.map((cat) => (
      <section
        class={`category-section${altIds.has(cat.id) ? ' alt-bg' : ''}`}
        aria-labelledby={`${cat.id}-heading`}
      >
        <div class="container">
          <h2 id={`${cat.id}-heading`} class="category-heading">
            <span class="category-line"></span>
            {cat.title}
          </h2>
          <div class="product-grid">
            {cat.products.map(p => (
              <article class="product-card card-glow">
                <img
                  src={`${base}/imgs/${p.image}`}
                  alt={p.name}
                  class="product-img"
                  loading="lazy"
                />
                <div class="product-body">
                  <h3 class="product-name">{p.name}</h3>
                  <p class="product-desc">{p.description}</p>
                  {p.variants && p.variants.length > 0 && (
                    <div class="variant-badges" aria-label="Modelos disponibles">
                      {p.variants.map(v => <span class="badge">{v}</span>)}
                    </div>
                  )}
                  <a href={contactoUrl} class="product-cta">Solicitar Info →</a>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>
    ))}
  </div>
</Layout>

<style>
  .page-wrapper {
    background: var(--color-bg);
  }
  .container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 24px;
  }
  .page-header {
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
    padding: 64px 0 48px;
  }
  .page-title {
    font-family: var(--font-display);
    font-size: clamp(48px, 8vw, 96px);
    color: var(--color-text);
    letter-spacing: 0.05em;
    margin: 0 0 16px;
  }
  .page-desc {
    color: var(--color-text-muted);
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.8;
    max-width: 700px;
    margin: 0;
  }
  .category-section {
    padding: 72px 0;
    background: var(--color-bg);
  }
  .alt-bg {
    background: var(--color-surface-alt);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }
  .category-heading {
    font-family: var(--font-display);
    font-size: clamp(28px, 4vw, 48px);
    color: var(--color-text);
    letter-spacing: 0.05em;
    margin: 0 0 40px;
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .category-line {
    display: block;
    width: 4px;
    height: 1em;
    background: var(--color-cyan);
    border-radius: 2px;
    flex-shrink: 0;
  }
  .product-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }
  @media (min-width: 640px) {
    .product-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (min-width: 1024px) {
    .product-grid { grid-template-columns: repeat(3, 1fr); }
  }
  .product-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  .product-img {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    display: block;
    background: var(--color-surface-alt);
  }
  .product-body {
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex: 1;
  }
  .product-name {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 15px;
    color: var(--color-text);
    margin: 0;
    line-height: 1.4;
  }
  .product-desc {
    color: var(--color-text-muted);
    font-size: 13px;
    line-height: 1.7;
    margin: 0;
    flex: 1;
  }
  .variant-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .badge {
    background: rgba(0, 200, 240, 0.1);
    color: var(--color-cyan);
    border: 1px solid rgba(0, 200, 240, 0.3);
    border-radius: 4px;
    padding: 3px 10px;
    font-size: 12px;
    font-family: var(--font-body);
    font-weight: 600;
    letter-spacing: 0.03em;
  }
  .product-cta {
    color: var(--color-cyan);
    text-decoration: none;
    font-size: 14px;
    font-weight: 600;
    transition: color 0.2s;
    align-self: flex-start;
    margin-top: auto;
  }
  .product-cta:hover {
    color: var(--color-glow);
  }
</style>
